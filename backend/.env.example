PORT=3000
NODE_ENV=production

# Database — PostgreSQL connection string
DATABASE_URL=postgresql://cosmicrealm:YOUR_PASSWORD@localhost:5432/cosmicrealm

# Database pool size
DB_POOL_MAX=10

# JWT secret (change in production!)
JWT_SECRET=change-me-in-production

# Redis (optional — enables multi-process Socket.IO)
REDIS_URL=

# Rate limits
API_RATE_LIMIT=300
AUTH_RATE_LIMIT=20
